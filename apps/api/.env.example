# Скопируйте в .env и подставьте свои значения.
# БД и Meilisearch: из корня репозитория — docker compose up -d

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/barter?schema=public"

# JWT и прочее — по необходимости (в коде есть dev-дефолт для JWT)
# JWT_SECRET=...

# --- Meilisearch (полнотекстовый поиск, подсказки, синонимы, опечатки) ---
MEILISEARCH_HOST=http://127.0.0.1:7700
# Если в Meilisearch включён master key:
# MEILISEARCH_API_KEY=...

# Интервал повторной попытки подключения к Meili при сбое (мс), по умолчанию 45000
# MEILISEARCH_RECONNECT_MS=45000

PORT=3001
